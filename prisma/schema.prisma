generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  TRIAL
  PRO
}

model User {
  id                       String    @id @default(cuid())
  name                     String?
  email                    String    @unique
  emailVerified            DateTime?
  image                    String?
  stripeCustomerId         String?   @unique
  stripePriceId            String?
  stripeSubscriptionId     String?   @unique
  stripeCurrentPeriodEnd   DateTime?
  trialEndsAt              DateTime?
  plan                     Plan      @default(FREE)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  mudancas  Mudanca[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Product Entities ──────────────────────────────────

enum MudancaStatus {
  RASCUNHO
  COTANDO
  CONFIRMADA
  CONCLUIDA
}

enum CategoriaItem {
  QUARTO
  COZINHA
  SALA
  ESCRITORIO
  BANHEIRO
  AREA_SERVICO
  CAIXAS
}

model Item {
  id              String        @id @default(cuid())
  nome            String
  categoria       CategoriaItem
  iconeUrl        String?
  larguraCm       Int
  alturaCm        Int
  profundidadeCm  Int
  pesoKg          Float
  volumeM3        Float
  customizado     Boolean       @default(false)
  userId          String?
  createdAt       DateTime      @default(now())

  cargaItens CargaItem[]

  @@index([categoria])
}

model Caminhao {
  id             String   @id @default(cuid())
  nome           String
  tipo           String
  capacidadeM3   Float
  capacidadeKg   Float
  comprimentoCm  Int
  larguraCm      Int
  alturaCm       Int
  imagemUrl      String?
  createdAt      DateTime @default(now())

  mudancas    Mudanca[]
  cargaLayouts CargaLayout[]
}

model Transportadora {
  id              String   @id @default(cuid())
  nome            String
  logoUrl         String?
  notaMedia       Float    @default(0)
  totalAvaliacoes Int      @default(0)
  cidade          String
  tiposCaminhao   String[]
  precoPorKm      Float    @default(3.50)  // R$ por km
  precoPorComodo  Float    @default(150.0) // R$ por cômodo
  taxaBase        Float    @default(200.0) // taxa fixa mínima R$
  tempoEstimadoDias Int    @default(3)     // dias úteis para entrega
  seguroIncluso   Boolean  @default(false)
  createdAt       DateTime @default(now())

  cotacoes Cotacao[]

  @@index([cidade])
}

model Mudanca {
  id              String        @id @default(cuid())
  userId          String
  enderecoOrigem  String
  enderecoDestino String
  dataDesejada    DateTime?
  caminhaoId      String?
  numComodos      Int           @default(1)
  distanciaKm     Float?
  status          MudancaStatus @default(RASCUNHO)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  caminhao     Caminhao?     @relation(fields: [caminhaoId], references: [id])
  cotacoes     Cotacao[]
  cargaLayout  CargaLayout?

  @@index([userId])
}

model Cotacao {
  id               String   @id @default(cuid())
  mudancaId        String
  transportadoraId String
  precoCentavos    Int
  dataDisponivel   DateTime
  seguroIncluso    Boolean  @default(false)
  validade         DateTime
  createdAt        DateTime @default(now())

  mudanca       Mudanca       @relation(fields: [mudancaId], references: [id], onDelete: Cascade)
  transportadora Transportadora @relation(fields: [transportadoraId], references: [id])

  @@index([mudancaId])
}

model CargaLayout {
  id                  String   @id @default(cuid())
  mudancaId           String   @unique
  caminhaoId          String
  ocupacaoPercentual  Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  mudanca  Mudanca     @relation(fields: [mudancaId], references: [id], onDelete: Cascade)
  caminhao Caminhao    @relation(fields: [caminhaoId], references: [id])
  itens    CargaItem[]
}

model CargaItem {
  id            String @id @default(cuid())
  cargaLayoutId String
  itemId        String
  x             Float  @default(0)
  y             Float  @default(0)
  rotacao       Int    @default(0)

  cargaLayout CargaLayout @relation(fields: [cargaLayoutId], references: [id], onDelete: Cascade)
  item        Item        @relation(fields: [itemId], references: [id])

  @@index([cargaLayoutId])
}
